# Copy this file to .env and fill in the values.
# The .env file must NEVER be committed to the repository.

# ── Database ────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/webshop
DB_USERNAME=webshop
DB_PASSWORD=localdev

# ── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters – use a random string in production
JWT_SECRET=change-this-to-a-random-secret-string-min-32-chars
# Token validity in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION_MS=86400000

# ── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Mail (optional – required for US #37, #55) ──────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=your-mail-password

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
