DB_PASSWORD=localdev

# ── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters – use a random string in production
JWT_SECRET=change-this-to-a-random-secret-string-min-32-chars
# Token validity in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION_MS=86400000

# ── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Mail ────────────────────────────────────────────────────────────────────
# Gmail: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587
# App-Passwort generieren: Google-Konto → Sicherheit → 2FA → App-Passwörter
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-account@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_SSL_ENABLE=false
# Sender address shown in outgoing emails
MAIL_FROM=your-account@gmail.com

# ── Alerting ─────────────────────────────────────────────────────────────────
# Kommagetrennte Liste von Alert-Empfängern. Standard ist MAIL_USERNAME (self-send).
# ALERT_ADMIN_EMAIL=deine@gmail.com,kollege@gmail.com
ALERT_ERROR_RATE_THRESHOLD=10
ALERT_HEAP_USAGE_THRESHOLD_PERCENT=85
